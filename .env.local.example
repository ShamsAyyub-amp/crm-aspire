# Copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. If unset, /api/ai/* returns mock responses.
ANTHROPIC_API_KEY=

# Optional. If unset, /api/email/send logs an activity and shows a mock 'sent' state.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
