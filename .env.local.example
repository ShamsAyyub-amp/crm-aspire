# Copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side LLM for /api/ai/* routes. If unset, every AI surface
# falls back to the heuristic engine and still works end-to-end.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional. Alternative LLM; not currently wired (heuristic + Gemini cover the AI routes).
ANTHROPIC_API_KEY=

# Optional. If unset, /api/email/send logs an activity and shows a mock 'sent' state.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
